      "severity": "major"
    },
    {
      "rule_id": "door_front_clearance",
      "name": "출입문 전방 장애물 금지",
      "type": "door_clearance",
      "target": "door_front",
      "distance": 100,
      "applyToKinds": ["bed", "locker", "desk", "chair", "storage", "equipment"],
