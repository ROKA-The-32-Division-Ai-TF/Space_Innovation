    {
      "rule_id": "equipment_near_door",
      "name": "장비함 출입문 주변 배치 금지",
      "type": "restricted_zone",
      "target": "door_zone",
      "distance": 120,
      "restrictedKinds": ["equipment", "storage"],
      "message": "장비함과 대형 보관함은 출입문 주변 120cm 이내 배치할 수 없습니다.",
      "severity": "major"
